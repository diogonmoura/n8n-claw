# ── n8n-claw environment ─────────────────────────────────────────────────────

# Your n8n public URL (must match your domain/reverse proxy config)
N8N_URL=https://n8n.yourdomain.com

# n8n internal URL (always localhost unless running n8n on a different host)
N8N_INTERNAL_URL=http://localhost:5678

# n8n port
N8N_PORT=5678

# ── Supabase / Postgres ───────────────────────────────────────────────────────
# These are auto-generated by setup.sh if left empty
POSTGRES_PASSWORD=
SUPABASE_JWT_SECRET=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Supabase Kong gateway URL (use server LAN IP, not localhost, so workflows can reach it)
SUPABASE_URL=http://YOUR_SERVER_IP:8000

# ── API keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: Brave Search API key for MCP Builder web search
BRAVE_API_KEY=no-brave-key

# ── User profile (for seed data) ─────────────────────────────────────────────
USER_TELEGRAM_ID=telegram:YOUR_TELEGRAM_ID
USER_NAME=your_username
USER_DISPLAY_NAME=Your Name
USER_TIMEZONE=Europe/London
USER_CONTEXT=Replace with a short description of yourself and your preferences
